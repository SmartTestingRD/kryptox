# Hoist Sharp (ya presente en el store como dependencia opcional de Astro) al
# node_modules raíz para que astro:assets pueda resolver `import('sharp')` bajo
# el aislamiento estricto de pnpm. No añade dependencias nuevas: solo expone la
# que ya estaba instalada (sharp@0.34.5 + @img/sharp-*).
public-hoist-pattern[]=*sharp*
public-hoist-pattern[]=@img/*

# Evita el prompt interactivo al recrear node_modules tras cambiar el hoist.
confirm-modules-purge=false
