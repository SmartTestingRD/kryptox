---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="What is KryptoX">
  <script is:inline>menuActive('about')</script>

<!-- ============================================================
     GLOBAL BASE — START
     Tokens, reset, tipografía, helpers, animaciones, reveal, KXParticles
     ============================================================ -->

<style>
/* --- GLOBAL: Design Tokens & Base --- */
.kx-about {
    --kx-bg:              #ffffff;
    --kx-bg-soft:         #f3f5f7;
    --kx-bg-softer:       #f6f8fa;
    --kx-text:            #0a0f12;
    --kx-text-soft:       rgba(10,15,18,0.72);
    --kx-text-muted:      rgba(10,15,18,0.54);
    --kx-border:          rgba(10,15,18,0.10);
    --kx-border-strong:   rgba(10,15,18,0.16);
    --kx-dark:            #000000;
    --kx-dark-2:          #071015;
    --kx-shadow-soft:     0 10px 30px rgba(0,0,0,0.10);
    --kx-shadow-card:     0 16px 44px rgba(0,0,0,0.10);
    --kx-shadow-deep:     0 26px 70px rgba(0,0,0,0.18);
    position: relative;
    background: var(--kx-bg);
    color: var(--kx-text);
    overflow: hidden;
}

/* --- GLOBAL: Container --- */
.kx-about__container {
    max-width: var(--innerWidth);
    margin: 0 auto;
    padding: 0 28px;
    position: relative;
    z-index: 2;
}

/* --- GLOBAL: Eyebrow pill (dark sections) --- */
.kx-about__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 25px;
    padding: 10px 16px;
    border-radius: 999px;
    border: 1px solid rgba(255,255,255,0.12);
    background: rgba(255,255,255,0.06);
    color: rgba(255,255,255,0.84);
    font-size: 12px;
    line-height: 1;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
}

.kx-about__eyebrowDot {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: var(--mainColor);
    box-shadow: 0 0 0 8px color-mix(in srgb, var(--mainColor) 12%, transparent);
    flex: 0 0 auto;
}

/* --- GLOBAL: Section label (light sections) --- */
.kx-about__sectionLabel {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 18px;
    color: color-mix(in srgb, var(--mainColor) 64%, #0a0f12);
    font-size: 13px;
    line-height: 1.4;
    letter-spacing: 0.08em;
    text-transform: uppercase;
}

.kx-about__sectionLabel::before {
    content: "";
    width: 22px;
    height: 1px;
    background: currentColor;
    opacity: 0.55;
}

/* --- GLOBAL: Section title & sub --- */
.kx-about__sectionTitle {
    margin: 0;
    font-size: 38px;
    line-height: 1.2;
    letter-spacing: -0.035em;
    font-weight: 200;
    color: var(--kx-text);
}

.kx-about__sectionSub {
    margin: 18px 0 0;
    max-width: 760px;
    font-size: 18px;
    line-height: 1.75;
    color: var(--kx-text-soft);
}

/* --- GLOBAL: Button base --- */
.kx-about__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    min-height: 50px;
    padding: 12px 24px;
    border-radius: 999px;
    text-decoration: none;
    border: 1px solid transparent;
    font-size: 15px;
    line-height: 1;
    font-weight: 600;
    transition: transform 160ms ease, box-shadow 160ms ease, filter 160ms ease,
                background 160ms ease, border-color 160ms ease, color 160ms ease;
    will-change: transform;
}

.kx-about__btn:hover { transform: translateY(-1px); filter: brightness(.94); }

.kx-about__btnPrimary {
    background: color-mix(in srgb, var(--mainColor) 88%, #000);
    color: #000;
    box-shadow: 0 18px 60px color-mix(in srgb, var(--mainColor) 22%, rgba(0,0,0,0.42));
}
.kx-about__btnPrimary:hover{ color: #000; }

.kx-about__btnSecondary {
    background: rgba(255,255,255,0.06);
    color: #fff;
    border-color: rgba(255,255,255,0.16);
    box-shadow: 0 12px 34px rgba(0,0,0,0.18);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
}

.kx-about__btnSecondary:hover {
    background: rgba(255,255,255,0.10);
    border-color: rgba(255,255,255,0.22);
    color: #fff;
}

.kx-about__btnIcon {
    width: 18px;
    height: 18px;
    fill: currentColor;
    flex: 0 0 auto;
}

/* --- GLOBAL: Section wrapper --- */
.kx-about__section { position: relative; padding: 108px 0; }
.kx-about__section--soft { background: var(--kx-bg-soft); }
.kx-about__section--dark {
    background:
        radial-gradient(circle at 18% 12%, rgba(0,191,194,0.14), transparent 24%),
        radial-gradient(circle at 84% 82%, rgba(0,191,194,0.10), transparent 20%),
        linear-gradient(180deg, #03080d 0%, #071015 100%);
    color: #fff;
}

.kx-about__section--dark .kx-about__sectionTitle { color: #fff; }
.kx-about__section--dark .kx-about__sectionSub   { color: rgba(255,255,255,0.72); }

/* --- GLOBAL: Canvas particle layer --- */
.kx-about__canvas {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    pointer-events: none;
    z-index: 0;
}

/* --- GLOBAL: Scroll reveal --- */
.kx-about__reveal {
    opacity: 0;
    transform: translateY(18px);
    transition: opacity 500ms ease, transform 500ms ease;
}

.kx-about__reveal.is_visible {
    opacity: 1;
    transform: translateY(0);
}

/* --- GLOBAL: Keyframes --- */
@keyframes kxAboutPulse {
    0%   { transform: scale(1); opacity: 0.9; }
    100% { transform: scale(5.4); opacity: 0; }
}

@keyframes kxAboutFlow {
    0%   { transform: translateX(-100%); }
    100% { transform: translateX(100%); }
}

@keyframes kxAboutSpin {
    0%   { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
}

/* responsive handled per-section below */

@media screen and (max-width: 450px) {
    .kx-about__sectionTitle{
        font-size: 30px;
    }
}
</style>

<!-- GLOBAL wrapper open -->
<section class="kx-about">

<script is:inline>
/* ============================================================
   GLOBAL: KXParticles Engine + Scroll Reveal
   ============================================================ */
(function(){

    /* --- Particle Engine --- */
    window.KXAboutParticles = function(canvasEl, opts) {
        var canvas = canvasEl;
        var ctx    = canvas.getContext('2d');
        var W, H, nodes = [], raf, startTime = null;

        var defaults = {
            type:    'network',
            count:   45,
            color:   '0,191,194',
            speed:   0.28,
            opacity: 0.35
        };
        var o = Object.assign({}, defaults, opts || {});

        function resize() {
            W = canvas.width  = canvas.offsetWidth;
            H = canvas.height = canvas.offsetHeight;
        }

        function rand(a, b) { return a + Math.random() * (b - a); }

        function initNodes() {
            nodes = [];
            for (var i = 0; i < o.count; i++) {
                nodes.push({
                    x:     rand(0, W),
                    y:     rand(0, H),
                    vx:    rand(-o.speed, o.speed),
                    vy:    rand(-o.speed * 0.6, o.speed * 0.6),
                    r:     rand(1.2, 2.6),
                    phase: rand(0, Math.PI * 2),
                    spd:   rand(0.003, 0.008)
                });
            }
        }

        function moveNodes() {
            for (var i = 0; i < nodes.length; i++) {
                var n = nodes[i];
                n.x += n.vx; n.y += n.vy;
                if (n.x < -20) n.x = W + 20;
                if (n.x > W+20) n.x = -20;
                if (n.y < -20) n.y = H + 20;
                if (n.y > H+20) n.y = -20;
            }
        }

        function drawNetwork(t) {
            ctx.clearRect(0, 0, W, H);
            for (var i = 0; i < nodes.length; i++) {
                for (var j = i+1; j < nodes.length; j++) {
                    var dx = nodes[i].x - nodes[j].x;
                    var dy = nodes[i].y - nodes[j].y;
                    var d  = Math.sqrt(dx*dx + dy*dy);
                    if (d < 120) {
                        var a = (1 - d/120) * 0.18 * o.opacity;
                        ctx.beginPath();
                        ctx.moveTo(nodes[i].x, nodes[i].y);
                        ctx.lineTo(nodes[j].x, nodes[j].y);
                        ctx.strokeStyle = 'rgba('+o.color+','+a+')';
                        ctx.lineWidth = 0.7;
                        ctx.stroke();
                    }
                }
            }
            for (var i = 0; i < nodes.length; i++) {
                var pulse = 0.4 + 0.6 * Math.sin(t * nodes[i].spd + nodes[i].phase);
                ctx.beginPath();
                ctx.arc(nodes[i].x, nodes[i].y, nodes[i].r, 0, Math.PI*2);
                ctx.fillStyle = 'rgba('+o.color+','+(pulse * o.opacity * 0.8)+')';
                ctx.fill();
            }
        }

        function drawFlow(t) {
            ctx.clearRect(0, 0, W, H);
            for (var i = 0; i < nodes.length; i++) {
                var n = nodes[i];
                var wave = Math.sin(t * 0.5 + n.phase) * 20;
                var a    = (0.25 + 0.25 * Math.sin(t * n.spd * 2 + n.phase)) * o.opacity;
                ctx.beginPath();
                ctx.arc(n.x, n.y + wave, n.r * 0.9, 0, Math.PI*2);
                ctx.fillStyle = 'rgba('+o.color+','+a+')';
                ctx.fill();
            }
        }

        function drawGrid(t) {
            ctx.clearRect(0, 0, W, H);
            var cols = Math.floor(W / 55);
            var rows = Math.floor(H / 55);
            for (var ci = 0; ci <= cols; ci++) {
                for (var ri = 0; ri <= rows; ri++) {
                    var x    = ci * 55;
                    var y    = ri * 55;
                    var dist = Math.sqrt(Math.pow(x-W/2,2) + Math.pow(y-H/2,2));
                    var wave = Math.sin(t * 0.4 - dist * 0.011);
                    var a    = (0.06 + 0.06 * wave) * o.opacity;
                    ctx.beginPath();
                    ctx.arc(x, y, 1.2, 0, Math.PI*2);
                    ctx.fillStyle = 'rgba('+o.color+','+a+')';
                    ctx.fill();
                }
            }
        }

        function drawScanner(t) {
            ctx.clearRect(0, 0, W, H);
            var scanY = ((t * 26) % (H + 60)) - 30;
            var grad  = ctx.createLinearGradient(0, scanY-50, 0, scanY+50);
            grad.addColorStop(0,   'rgba('+o.color+',0)');
            grad.addColorStop(0.5, 'rgba('+o.color+','+(0.05 * o.opacity)+')');
            grad.addColorStop(1,   'rgba('+o.color+',0)');
            ctx.fillStyle = grad;
            ctx.fillRect(0, scanY-50, W, 100);
            for (var i = 0; i < nodes.length; i++) {
                var n = nodes[i];
                var a = (0.12 + 0.08 * Math.sin(t * n.spd + n.phase)) * o.opacity;
                ctx.beginPath();
                ctx.arc(n.x, n.y, n.r * 0.8, 0, Math.PI*2);
                ctx.fillStyle = 'rgba('+o.color+','+a+')';
                ctx.fill();
            }
        }

        function drawWave(t) {
            ctx.clearRect(0, 0, W, H);
            for (var i = 0; i < nodes.length; i++) {
                var n  = nodes[i];
                var wo = Math.sin(t * 0.4 + n.x * 0.014 + n.phase) * 28;
                var a  = (0.18 + 0.12 * Math.sin(t * n.spd + n.phase)) * o.opacity;
                ctx.beginPath();
                ctx.arc(n.x, n.y + wo, n.r, 0, Math.PI*2);
                ctx.fillStyle = 'rgba('+o.color+','+a+')';
                ctx.fill();
            }
        }

        function loop(ts) {
            if (!startTime) startTime = ts;
            var t = (ts - startTime) * 0.001;
            moveNodes();
            if      (o.type === 'network') drawNetwork(t);
            else if (o.type === 'flow')    drawFlow(t);
            else if (o.type === 'grid')    drawGrid(t);
            else if (o.type === 'scanner') drawScanner(t);
            else if (o.type === 'wave')    drawWave(t);
            raf = requestAnimationFrame(loop);
        }

        function init() { resize(); initNodes(); raf = requestAnimationFrame(loop); }
        window.addEventListener('resize', function(){ resize(); initNodes(); });
        init();
        return { destroy: function(){ cancelAnimationFrame(raf); } };
    };

    /* --- Scroll Reveal Observer --- */
    document.addEventListener('DOMContentLoaded', function(){
        var root = document.querySelector('.kx-about');
        if (!root) return;

        var items = root.querySelectorAll('.kx-about__reveal');

        if ('IntersectionObserver' in window) {
            var io = new IntersectionObserver(function(entries){
                entries.forEach(function(e){
                    if (e.isIntersecting) {
                        e.target.classList.add('is_visible');
                        io.unobserve(e.target);
                    }
                });
            }, { threshold: 0.14, rootMargin: '0px 0px -40px 0px' });

            items.forEach(function(item){ io.observe(item); });
        } else {
            items.forEach(function(item){ item.classList.add('is_visible'); });
        }

        /* --- Smooth anchor scroll --- */
        root.querySelectorAll('a[href^="#"]').forEach(function(link){
            link.addEventListener('click', function(e){
                var href = link.getAttribute('href');
                if (!href || href === '#') return;
                var target = document.querySelector(href);
                if (!target) return;
                e.preventDefault();
                target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            });
        });

        /* --- Init all section canvases --- */
        root.querySelectorAll('.kx-about__canvas').forEach(function(canvas){
            KXAboutParticles(canvas, {
                type:    canvas.dataset.type    || 'network',
                count:   parseInt(canvas.dataset.count   || '40', 10),
                color:   canvas.dataset.color   || '0,191,194',
                speed:   parseFloat(canvas.dataset.speed || '0.28'),
                opacity: parseFloat(canvas.dataset.opacity || '0.3')
            });
        });
    });
})();
</script>

<!-- ============================================================
     GLOBAL BASE — END
     ============================================================ -->


<!-- ============================================================
     SECTION 1: HERO — START
     ============================================================ -->

<style>
/* --- HERO --- */
.kx-about__hero {
    position: relative;
    padding: 128px 0 110px;
    background:
        radial-gradient(circle at 15% 18%, rgba(0,191,194,0.18), transparent 24%),
        radial-gradient(circle at 84% 24%, rgba(0,191,194,0.12), transparent 20%),
        linear-gradient(180deg, #000000 0%, #071015 100%);
    color: #fff;
    isolation: isolate;
}

.kx-about__hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
        linear-gradient(rgba(255,255,255,0.035) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.035) 1px, transparent 1px);
    background-size: 72px 72px;
    opacity: 0.34;
    pointer-events: none;
}

.kx-about__hero::after {
    content: "";
    position: absolute;
    left: 0; right: 0; bottom: 0;
    height: 160px;
    background: linear-gradient(180deg, rgba(255,255,255,0) 0%, rgba(255,255,255,0.08) 100%);
    pointer-events: none;
}

.kx-about__heroGrid {
    display: grid;
    grid-template-columns: minmax(0,1.06fr) minmax(460px,0.94fr);
    gap: 48px;
    align-items: center;
}

.kx-about__heroTitle {
    margin: 24px 0 0;
    max-width: 780px;
    font-size: 68px;
    line-height: 0.97;
    letter-spacing: -0.05em;
    font-weight: 600;
    color: #fff;
}

.kx-about__heroSub {
    margin: 24px 0 0;
    max-width: 700px;
    font-size: 17px;
    line-height: 1.58;
    color: rgba(255,255,255,0.82);
}

.kx-about__heroText {
    margin: 18px 0 0;
    max-width: 670px;
    font-size: 16px;
    line-height: 1.8;
    color: rgba(255,255,255,0.62);
        display: none;
}

.kx-about__heroActions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 34px;
}

/* Mini stat cards */
.kx-about__heroMini {
    display: grid;
    grid-template-columns: repeat(3, minmax(0,1fr));
    gap: 14px;
    margin-top: 40px;
    max-width: 720px;
}

.kx-about__heroMiniCard {
    padding: 16px 18px;
    border-radius: 16px;
    background: rgba(255,255,255,0.055);
    border: 1px solid rgba(255,255,255,0.10);
    box-shadow: 0 14px 36px rgba(0,0,0,0.22);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    transition: transform 160ms ease, border-color 160ms ease, background 160ms ease;
}

.kx-about__heroMiniCard:hover {
    transform: translateY(-2px);
    border-color: rgba(255,255,255,0.18);
    background: rgba(255,255,255,0.08);
}

.kx-about__heroMiniLabel {
    display: block;
    margin-bottom: 8px;
    color: rgba(255,255,255,0.52);
    font-size: 11px;
    line-height: 1;
    letter-spacing: 0.08em;
    text-transform: uppercase;
}

.kx-about__heroMiniValue {
    display: block;
    color: #fff;
    font-size: 15px;
    line-height: 1.4;
}

/* Hero visual diagram */
.kx-about__heroVisual {
    position: relative;
    min-height: 620px;
    display: flex;
    align-items: center;
    justify-content: center;
}

.kx-about__heroCore {
    position: relative;
    width: min(100%, 620px);
    aspect-ratio: 1 / 1;
}

.kx-about__heroCore::before {
    content: "";
    position: absolute;
    inset: 12% 12%;
    border-radius: 999px;
    border: 1px solid rgba(255,255,255,0.08);
    box-shadow: 0 0 0 1px rgba(255,255,255,0.02) inset;
}

.kx-about__heroCore::after {
    content: "";
    position: absolute;
    inset: 24% 24%;
    border-radius: 999px;
    border: 1px dashed rgba(255,255,255,0.10);
    animation: kxAboutSpin 18s linear infinite;
}

/* Node cards */
.kx-about__node {
    position: absolute;
    padding: 18px 20px;
    border-radius: 18px;
    background: linear-gradient(180deg, rgba(255,255,255,0.10) 0%, rgba(255,255,255,0.045) 100%);
    border: 1px solid rgba(255,255,255,0.14);
    box-shadow: 0 18px 50px rgba(0,0,0,0.24);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    transition: transform 160ms ease, border-color 160ms ease, background 160ms ease;
}

.kx-about__node:hover {
    transform: translateY(-2px);
    border-color: rgba(255,255,255,0.22);
    background: linear-gradient(180deg, rgba(255,255,255,0.12) 0%, rgba(255,255,255,0.06) 100%);
}

.kx-about__node--center {
    left: 50%; top: 50%;
    width: 240px;
    transform: translate(-50%, -50%);
    text-align: center;
    border-radius: 26px;
    background:
        radial-gradient(circle at 50% 0%, rgba(0,191,194,0.22), transparent 46%),
        linear-gradient(180deg, rgba(255,255,255,0.14) 0%, rgba(255,255,255,0.06) 100%);
    border-color: rgba(0,191,194,0.18);
    box-shadow: 0 24px 80px rgba(0,0,0,0.34);
    z-index: 3;
}

.kx-about__node--center:hover { transform: translate(-50%, calc(-50% - 2px)); border-color: rgba(0,191,194,0.34); }
.kx-about__node--crypto  { top: 7%;  right: 8%;   width: 190px; z-index: 2; }
.kx-about__node--bank    { right: 2%; bottom: 14%; width: 210px; z-index: 2; }
.kx-about__node--controls{ left: 8%; bottom: 10%; width: 200px; z-index: 2; }

.kx-about__nodeLabel {
    display: block;
    margin-bottom: 9px;
    color: rgba(255,255,255,0.50);
    font-size: 11px;
    line-height: 1;
    letter-spacing: 0.08em;
    text-transform: uppercase;
}

.kx-about__nodeTitle {
    display: block;
    color: #fff;
    font-size: 17px;
    line-height: 1.3;
    letter-spacing: -0.02em;
    font-weight: 600;
}

.kx-about__nodeText {
    margin: 8px 0 0;
    color: rgba(255,255,255,0.62);
    font-size: 13px;
    line-height: 1.65;
}

/* Pulse rings */
.kx-about__pulse {
    position: absolute;
    left: 50%; top: 50%;
    width: 84px; height: 84px;
    border-radius: 999px;
    background: #00d7d717;
    transform: translate(-50%, -50%);
    box-shadow: 0 0 0 10px rgba(0,191,194,0.12);
    z-index: 1;
}

.kx-about__pulse::before,
.kx-about__pulse::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 999px;
    border: 1px solid rgba(0,191,194,0.48);
    animation: kxAboutPulse 2.6s ease-out infinite;
}

.kx-about__pulse::after { animation-delay: 1.2s; }

/* Flow lines */
.kx-about__line {
    position: absolute;
    overflow: hidden;
    pointer-events: none;
    z-index: 1;
}

.kx-about__line::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 999px;
    background: linear-gradient(90deg, rgba(0,191,194,0) 0%, rgba(0,191,194,0.65) 50%, rgba(255,255,255,0) 100%);
    transform: translateX(-100%);
    animation: kxAboutFlow 3.8s linear infinite;
}

.kx-about__line--top   { left: 54%; top: 24%;  width: 190px; height: 1px; transform: rotate(-28deg); background: linear-gradient(90deg, rgba(255,255,255,0.10), rgba(255,255,255,0.12)); }
.kx-about__line--right { left: 56%; top: 56%;  width: 196px; height: 1px; transform: rotate(28deg);  background: linear-gradient(90deg, rgba(255,255,255,0.10), rgba(255,255,255,0.12)); }
.kx-about__line--left  { left: 23%; top: 62%;  width: 178px; height: 1px; transform: rotate(-28deg); background: linear-gradient(90deg, rgba(255,255,255,0.10), rgba(255,255,255,0.12)); }

/* ---- HERO: Responsive — START ---- */
@media (max-width: 1266px) {
    .kx-about__heroGrid {
        grid-template-columns: 1fr;
    }
    .kx-about__heroVisual { display: none; }
    .kx-about__heroTitle  { font-size: 54px; max-width: 100%; }
    .kx-about__heroSub    { font-size: 19px; }
    .kx-about__heroMini   { max-width: 100%; }
}

@media (max-width: 800px) {
    .kx-about__heroMini {
        grid-template-columns: 1fr;
