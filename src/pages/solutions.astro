<script is:inline>
/* Original PHP usaba jQuery: $('[scroll="..."]'). El proyecto Astro no carga
   jQuery, así que se reescribe el mismo comportamiento en JS vanilla. */
document.addEventListener('DOMContentLoaded', function () {
  function getScrollTarget() {
    const params = new URLSearchParams(window.location.search);
    const section = params.get('i');

    if (!section) return null;

    const target = document.querySelector('[scroll="' + section + '"]');
    if (!target) return null;

    return target;
  }

  function scrollToQuerySection() {
    const target = getScrollTarget();
    if (!target) return;

    setTimeout(() => {
      const headerOffset = 100; // Ajusta según la altura real de tu header
      const targetPosition = target.getBoundingClientRect().top + window.pageYOffset - headerOffset;

      window.scrollTo({
        top: targetPosition,
        behavior: 'smooth'
      });
    }, 120);
  }

  scrollToQuerySection();

  // Si por alguna razón cambias el query string sin recargar
  window.addEventListener('popstate', scrollToQuerySection);
});
</script>

</BaseLayout>
