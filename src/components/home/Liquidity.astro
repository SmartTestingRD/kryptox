---
/**
 * Liquidity.astro
 * ---------------
 * 1:1 migration of part/sub/home/liquidez.php. HTML, CSS and inline script
 * ported verbatim. `$raiz` resolves to `/`.
 */
---

<section class="kx-liq">
  <div class="kx-liq__inner">

    <!-- circular video -->
    <div class="kx-liq__media">
      <video
        src="/media/moneda_1.mp4"
        autoplay
        muted
        loop
        playsinline
      ></video>
    </div>

    <!-- text -->
    <div class="kx-liq__content">
      <h3 class="kx-liq__title">
        Reliable Liquidity. Controlled Settlements.
      </h3>
      <p class="kx-liq__desc">
        Access institutional liquidity while defining when, how, and under which
        conditions funds are settled.
      </p>
    </div>

    <!-- CTA -->
    <div class="kx-liq__cta">
      <a href="#">
        <button class="kx-liq__btn">Learn More</button>
      </a>
    </div>

  </div>
</section>

<style>
  /* ===== KryptoX — Liquidity Video CTA ===== */

  .kx-liq{
    background:#000;
    color:#fff;
    padding: 40px 28px;
  }

  .kx-liq__inner{
    max-width: var(--innerWidth);
    padding: 0px 150px;
    margin:0 auto;
    display:flex;
    align-items:center;
    gap:36px;
  }

  /* circular video */
  .kx-liq__media{
    width:120px;
    height:120px;
    border-radius:999px;
    overflow:hidden;
    flex:0 0 120px;
      margin-top: -5px;
  }

  .kx-liq__media video{
    width:100%;
    height:100%;
    object-fit:cover;
    display:block;
    margin-top: 5px;
  }

  .kx-liq__content{
    flex:1;
  }

  .kx-liq__title{
    margin:0 0 10px 0;
    font-size:clamp(22px,3vw,32px);
    font-weight: 300;
    letter-spacing:-0.01em;
  }

  .kx-liq__desc{
    margin:0;
    font-size:14px;
    line-height:1.7;
    color:rgba(255,255,255,0.75);
    max-width:720px;
  }

  .kx-liq__cta{
    margin-left:auto;
  }

  .kx-liq__btn{
    appearance:none;
    border:none;
    border-radius:999px;
    padding:14px 26px;
    background:#3a3a3a;
    color:#fff;
    font-size:14px;
    font-weight:600;
    cursor:pointer;
    transition:background 160ms ease, transform 160ms ease;
  }

  .kx-liq__btn:hover{
    background:#4a4a4a;
    transform:translateY(-1px);
  }

  /* ---- LIQUIDEZ: Responsive — START ---- */

  /* ≤1343px: remove lateral padding, content fills full width */
  @media (max-width: 1343px){
    .kx-liq__inner{
      padding-left: 0;
      padding-right: 0;
    }
  }

  /* ≤981px: hide CTA button, flex keeps video + content as 2-item row */
  @media (max-width: 981px){
    .kx-liq__cta{
      display: none;
    }
    .kx-liq__inner{
      padding-left: 28px;
      padding-right: 28px;
    }
  }

  /* ≤540px: vertical layout — video centered on top, text below */
  @media (max-width: 540px){
    .kx-liq__inner{
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding-left: 22px;
      padding-right: 22px;
      gap: 20px;
    }
    .kx-liq__content{
      width: 100%;
    }
  }

  /* ---- LIQUIDEZ: Responsive — END ---- */
</style>

<script is:inline>
  (function(){
    // placeholder hook if later you want to control playback
    const video = document.querySelector('.kx-liq__media video');
    if(!video) return;

    // ensure autoplay even on some browsers
    video.muted = true;
    video.play().catch(()=>{});
  })();
</script>
