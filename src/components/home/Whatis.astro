---
/**
 * Whatis.astro
 * ------------
 * 1:1 migration of part/sub/home/whatis.php. HTML, CSS and inline scripts
 * ported verbatim. `$raiz` resolves to `/`.
 *
 * The shared KXHomeParticles engine is defined here (as in the PHP original)
 * and reused by Steps; the `.kx-home__canvas` rule is emitted globally so it
 * also styles the canvas rendered by other home sections.
 */
import { Image } from 'astro:assets';
import logoHead from '../../assets/logo.head.png';
---

<section class="kx-what" id="kxWhat">
  <canvas class="kx-home__canvas" data-color="10,80,110" data-count="28" data-speed="0.16" data-opacity="0.17" aria-hidden="true"></canvas>
  <div class="kx-what__inner">
    <div class="kx-what__text">
      <h2 class="kx-what__title">What is <b>KryptoX</b>?</h2>

      <p class="kx-what__desc">
        KryptoX is an orchestration layer, we provide a <b>crypto-to-bank</b> liquidity infrastructure built for
        performance and discretion. We provide seamless conversion from digital assets to fiat, with full
        compliance and settlement into your bank account in under one hour — no delays, no complexity.
      </p>

      <div class="kx-what__groups">
        <div class="kx-what__group">
          <div class="kx-what__label">What we do</div>
          <ul class="kx-what__items" role="list">
            <li class="kx-what__item">Orchestrate flows <span class="kx-what__dot" aria-hidden="true"></span></li>
            <li class="kx-what__item">Enforce rules <span class="kx-what__dot" aria-hidden="true"></span></li>
            <li class="kx-what__item">Aggregate liquidity <span class="kx-what__dot" aria-hidden="true"></span></li>
            <li class="kx-what__item">Ensure compliance</li>
          </ul>
        </div>

        <div class="kx-what__group">
          <div class="kx-what__label kx-what__label--dont">What we don't do</div>
          <ul class="kx-what__items kx-what__items--dont" role="list">
            <li class="kx-what__item">Hold your funds <span class="kx-what__dot" aria-hidden="true"></span></li>
            <li class="kx-what__item">Act as a bank <span class="kx-what__dot" aria-hidden="true"></span></li>
            <li class="kx-what__item">Speculate with assets <span class="kx-what__dot" aria-hidden="true"></span></li>
            <li class="kx-what__item">Charge hidden spreads</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="kx-what__art" aria-hidden="true">
      <Image
        class="kx-what__logo"
        src={logoHead}
        alt=""
        loading="lazy"
      />
    </div>
  </div>
</section>

<style>
  /* KryptoX — Section: What is KryptoX? */
  .kx-what{
    position: relative;
    background: #ffffff;
    color: #0b0f12;
    padding: 170px 0;
    overflow: hidden;
  }

  .kx-what__inner{
    position: relative;
    z-index: 2;
    max-width: var(--innerWidth);
    margin: 0 auto;
    padding: 0 28px;
    display: grid;
    grid-template-columns: 1.35fr 0.9fr;
    gap: 70px;
    align-items: center;
  }

  .kx-what__title{
    margin: 0 0 14px 0;
    font-weight: 200;
    letter-spacing: -0.02em;
    line-height: 1.04;
    font-size: var(--titleSize);
    color: #0a0f12;
  }

  .kx-what__title b{
    font-weight: 900;
  }

  .kx-what__desc{
    margin: 0;
    max-width: 720px;
    font-size: 16px;
    line-height: 1.75;
    color: rgba(10,15,18,0.72);
  }

  .kx-what__desc b{
    color: rgba(10,15,18,0.92);
    font-weight: 800;
  }

  .kx-what__groups{
    margin-top: 44px;
    display: grid;
    gap: 46px;
    max-width: 760px;
  }

  .kx-what__group{
    display: grid;
    gap: 14px;
  }

  .kx-what__label{
    display: flex;
    align-items: center;
    gap: 14px;
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(10,15,18,0.72);
  }

  .kx-what__label::before{
    content:"";
    width: 34px;
    height: 1px;
    background: rgba(10,15,18,0.18);
  }

  .kx-what__label--dont{
    color: rgba(200,24,24,0.88);
  }

  .kx-what__label--dont::before{
    background: rgba(200,24,24,0.28);
  }

  .kx-what__items{
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 14px 18px;
    padding-left: 0;
    margin: 0;
    list-style: none;
  }

  .kx-what__item{
    display: inline-flex;
    align-items: center;
    gap: 14px;
    font-size: 15px;
    font-weight: 700;
    color: rgba(10,15,18,0.88);
    white-space: nowrap;
  }

  .kx-what__dot{
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(10,15,18,0.18);
    transform: translateY(1px);
  }

  .kx-what__items--dont .kx-what__item{
    color: rgba(10,15,18,0.46);
    font-weight: 650;
  }

  .kx-what__items--dont .kx-what__dot{
    background: rgba(10,15,18,0.14);
  }

  /* Right logo block */
  .kx-what__art{
    display: grid;
    place-items: center;
    min-height: 320px;
  }

  .kx-what__logo{
    width: min(260px, 85%);
    height: auto;
    display: block;
    filter: drop-shadow(0 28px 65px rgba(0,0,0,0.10));
    transform: translateZ(0);
    opacity: 0;
    transform: translateY(10px) scale(0.985);
    transition: opacity 500ms ease, transform 500ms ease;
  }

  .kx-what.is-inview .kx-what__logo{
    opacity: 1;
    transform: translateY(0px) scale(1);
  }

  .kx-what__text{
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 520ms ease, transform 520ms ease;
  }

  .kx-what.is-inview .kx-what__text{
    opacity: 1;
    transform: translateY(0px);
  }

  /* Responsive */
  @media (max-width: 980px){
    .kx-what{
      padding: 88px 0 96px;
    }

    .kx-what__inner{
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .kx-what__art{
      min-height: 220px;
      order: -1;
    }

    .kx-what__logo{
      width: min(220px, 70%);
    }
  }

  @media (prefers-reduced-motion: reduce){
    .kx-what__logo,
    .kx-what__text{
      transition: none;
      opacity: 1 !important;
      transform: none !important;
    }
  }
</style>

<!-- Shared home particle canvas — global so it also styles other sections' canvases -->
<style is:global>
  /* --- HOME PARTICLES canvas --- */
  .kx-home__canvas{
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    pointer-events: none;
    z-index: 0;
  }
</style>

<script is:inline>
  (function(){
    var el = document.getElementById('kxWhat');
    if (!el) {
      console.warn('[KryptoX] #kxWhat not found. Section may not be included/loaded.');
      return;
    }

    if ('IntersectionObserver' in window) {
      var io = new IntersectionObserver(function(entries){
        for (var i=0; i<entries.length; i++){
          if (entries[i].isIntersecting) {
            el.classList.add('is-inview');
            io.disconnect();
            break;
          }
        }
      }, { threshold: 0.2 });

      io.observe(el);
    } else {
      // Fallback
      el.classList.add('is-inview');
    }
  })();
</script>

<script is:inline>
/* ============================================================
   HOME: KXHomeParticles engine (shared across home sections)
   ============================================================ */
window.KXHomeParticles = window.KXHomeParticles || function(canvasEl, opts) {
    var canvas = canvasEl;
    var ctx    = canvas.getContext('2d');
    var W, H, nodes = [], raf;
    var defaults = { count: 32, color: '10,80,110', speed: 0.18, opacity: 0.07 };
    var o = Object.assign({}, defaults, opts || {});

    function resize() { W = canvas.width = canvas.offsetWidth; H = canvas.height = canvas.offsetHeight; }
    function rand(a,b) { return a + Math.random() * (b - a); }

    function initNodes() {
        nodes = [];
        for (var i = 0; i < o.count; i++) {
            nodes.push({
                x:  rand(0, W), y:  rand(0, H),
                vx: rand(-o.speed, o.speed),
                vy: rand(-o.speed, o.speed),
                r:  rand(1.4, 2.8)
            });
        }
    }

    function moveNodes() {
        for (var i = 0; i < nodes.length; i++) {
            nodes[i].x += nodes[i].vx;
            nodes[i].y += nodes[i].vy;
            if (nodes[i].x < 0 || nodes[i].x > W) nodes[i].vx *= -1;
            if (nodes[i].y < 0 || nodes[i].y > H) nodes[i].vy *= -1;
        }
    }

    function draw() {
        ctx.clearRect(0, 0, W, H);
        for (var i = 0; i < nodes.length; i++) {
            for (var j = i + 1; j < nodes.length; j++) {
                var dx = nodes[i].x - nodes[j].x;
                var dy = nodes[i].y - nodes[j].y;
                var d  = Math.sqrt(dx*dx + dy*dy);
                if (d < 130) {
                    ctx.beginPath();
                    ctx.moveTo(nodes[i].x, nodes[i].y);
                    ctx.lineTo(nodes[j].x, nodes[j].y);
                    ctx.strokeStyle = 'rgba(' + o.color + ',' + (o.opacity * (1 - d / 130) * 0.55) + ')';
                    ctx.lineWidth = 0.7;
                    ctx.stroke();
                }
            }
            ctx.beginPath();
            ctx.arc(nodes[i].x, nodes[i].y, nodes[i].r, 0, Math.PI * 2);
            ctx.fillStyle = 'rgba(' + o.color + ',' + o.opacity + ')';
            ctx.fill();
        }
    }

    function loop() { moveNodes(); draw(); raf = requestAnimationFrame(loop); }

    window.addEventListener('resize', function() { resize(); initNodes(); });
    resize(); initNodes(); raf = requestAnimationFrame(loop);
    return { destroy: function(){ cancelAnimationFrame(raf); } };
};

/* --- WHATIS: init canvas particles --- */
(function(){
    var canvas = document.querySelector('#kxWhat .kx-home__canvas');
    if (!canvas || typeof KXHomeParticles === 'undefined') return;
    KXHomeParticles(canvas, {
        color:   canvas.dataset.color   || '10,80,110',
        count:   parseInt(canvas.dataset.count  || '28', 10),
        speed:   parseFloat(canvas.dataset.speed  || '0.16'),
        opacity: parseFloat(canvas.dataset.opacity || '0.07')
    });
})();
</script>
