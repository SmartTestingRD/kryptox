---
/**
 * Realtime.astro
 * --------------
 * 1:1 migration of part/sub/home/realtime.php. HTML, CSS and inline script
 * ported verbatim. `$raiz` resolves to `/`.
 */
---

<section class="kx-realtime" id="kxRealtime">
  <div class="kx-realtime__bg" aria-hidden="true"></div>

  <div class="kx-realtime__inner">
    <div class="kx-realtime__reveal">
      <h2 class="kx-realtime__title">Near-Real-Time Fiat Settlements</h2>
      <p class="kx-realtime__desc">
        KryptoX enables near-real-time crypto-to-fiat settlements—often within one hour—by orchestrating
        liquidity providers, approval flows, and banking rails in a single workflow.
      </p>
    </div>
  </div>
</section>

<style>
  /* KryptoX — Section: Near-Real-Time Fiat Settlements (Banner) */
  .kx-realtime{
    position: relative;
    width: 100%;
    background: #11D6D1; /* cyan base */
    overflow: hidden;
  }

  .kx-realtime__inner{
    max-width: var(--innerWidth);
    margin: 0 auto;
    padding: 30px 0px;
    display: grid;
    grid-template-columns: 1.4fr 0.6fr;
    align-items: center;
    gap: 40px;
    position: relative;
    z-index: 2;
  }

  /* Left content */
  .kx-realtime__title{
    margin: 0 0 14px 0;
    font-size: clamp(34px, 3.2vw, 32px);
    line-height: 1.08;
    font-weight: 900;
    letter-spacing: -0.02em;
    color: #000;
  }

  .kx-realtime__desc{
    margin: 0;
    max-width: 590px;
    font-size: 14px;
    line-height: 1.65;
    color: rgba(0,0,0,0.78);
  }

  /* Right background image */
  .kx-realtime__bg{
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: 52%;
    background-image: url('/media/realtime.bg.png');
    background-repeat: no-repeat;
    background-position: right center;
    background-size: cover;
    pointer-events: none;
  }

  /* Soft overlay to blend image */
  .kx-realtime__bg::after{
    content:"";
    position:absolute;
    inset:0;
    background: linear-gradient(
      to left,
      rgba(17,214,209,0.0),
      rgba(17,214,209,0.65),
      rgba(17,214,209,0.95)
    );
  }

  /* Entrance animation */
  .kx-realtime__reveal{
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 520ms ease, transform 520ms ease;
  }

  .kx-realtime.is-inview .kx-realtime__reveal{
    opacity: 1;
    transform: translateY(0);
  }

  /* ---- REALTIME: Responsive — START ---- */

  /* ≤1415px: add padding-left so content doesn't hug the edge */
  @media (max-width: 1415px){
    .kx-realtime__inner{
      padding-left: 40px;
      padding-right: 40px;
    }
  }

  /* ≤961px: single column, text centered, bg hidden */
  @media (max-width: 961px){
    .kx-realtime__inner{
      grid-template-columns: 1fr;
      padding: 40px 28px;
      justify-items: center;
      text-align: center;
    }

    .kx-realtime__bg{
      display: none;
    }

    .kx-realtime__desc{
      margin: 0 auto;
    }
  }

  /* ---- REALTIME: Responsive — END ---- */

  @media (prefers-reduced-motion: reduce){
    .kx-realtime__reveal{
      transition: none;
      opacity: 1 !important;
      transform: none !important;
    }
  }
</style>

<script is:inline>
  (function(){
    var el = document.getElementById('kxRealtime');
    if (!el){
      console.warn('[KryptoX] #kxRealtime not found.');
      return;
    }

    if ('IntersectionObserver' in window){
      var io = new IntersectionObserver(function(entries){
        for (var i=0;i<entries.length;i++){
          if (entries[i].isIntersecting){
            el.classList.add('is-inview');
            io.disconnect();
            break;
          }
        }
      },{ threshold:0.25 });
      io.observe(el);
    } else {
      el.classList.add('is-inview');
    }
  })();
</script>
