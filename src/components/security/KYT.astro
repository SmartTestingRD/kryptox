---
/**
 * KYT.astro
 * ---------
 * 1:1 migration of part/sub/security/kyt.php. HTML, CSS and inline script
 * ported verbatim. `$raiz` resolves to `/`.
 */
import { Image } from 'astro:assets';
import kyt from '../../assets/security/kyt.png';
---

<section class="kx-tm" id="kxTM">
  <div class="kx-tm__inner">
    <div class="kx-tm__card kx-tm__reveal">

      <!-- Left -->
      <div class="kx-tm__content">
        <h2 class="kx-tm__title">
          <strong style="font-size: 28px; font-weight: 500;">KYT / AML</strong><br>
          Transaction Monitoring
        </h2>

        <p class="kx-tm__desc">
          Every crypto transaction is analyzed before settlement—combining KYT signals,
          AML rules, and risk scoring to detect anomalies, flag exposure, and manage
          exceptions in real time.
        </p>

        <div class="kx-tm__points">
          <div class="kx-tm__point">
            <span class="kx-tm__dot"></span>
            Pre-settlement transaction screening and risk classification
          </div>
          <div class="kx-tm__point">
            <span class="kx-tm__dot"></span>
            Automated alerts for suspicious activity and policy breaches
          </div>
          <div class="kx-tm__point">
            <span class="kx-tm__dot"></span>
            Manual review workflows with full audit context and traceability
          </div>
        </div>
      </div>

      <!-- Right -->
      <div class="kx-tm__visual">
        <div class="kx-tm__imageWrap">
          <!-- Placeholder image -->
          <Image src={kyt} alt="Transaction monitoring placeholder" />
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  /* ===== Security & Compliance — Transaction Monitoring (KYT / AML) ===== */

  .kx-tm{
    background:#ffffff;
    padding: 50px 28px 120px ;
    display:flex;
    justify-content:center;
  }

  .kx-tm__inner{
    max-width: var(--innerWidth);
    width:100%;
    display:flex;
    justify-content:center;
  }

  .kx-tm__card{
    position:relative;
    width:100%;
    max-width:1100px;
    min-height:420px;
    border-radius:28px;
    padding:64px 68px;
    display:grid;
    grid-template-columns: 1.1fr 0.9fr;
    align-items:center;
    gap:48px;
    color:#ffffff;
    background:
      radial-gradient(120% 120% at 10% 10%, rgba(255,255,255,0.18), transparent 55%),
      linear-gradient(145deg, #0b1220 0%, #111c33 45%, #0a0f1c 100%);


    box-shadow:
      0 40px 120px rgba(0,0,0,0.35),
      inset 0 0 0 1px rgba(255,255,255,0.18);
    overflow:hidden;
  }

  /* soft glow accents */
  .kx-tm__card::before{
    content:"";
    position:absolute;
    top:-120px;
    left:-120px;
    width:340px;
    height:340px;
    background:radial-gradient(circle, rgba(255,255,255,0.35), transparent 70%);
    opacity:0.5;
    pointer-events:none;
  }

  .kx-tm__card::after{
    content:"";
    position:absolute;
    bottom:-140px;
    right:-140px;
    width:380px;
    height:380px;
    background:radial-gradient(circle, rgba(0,0,0,0.25), transparent 70%);
    opacity:0.4;
    pointer-events:none;
  }

  /* left content */
  .kx-tm__title{
    margin:0 0 22px 0;
    font-size:clamp(34px, 4.5vw, 44px);
    line-height:1.08;
    font-weight:200; /* requested */
    letter-spacing:-0.02em;
    color:#ffffff;
  }

  .kx-tm__desc{
    margin:0 0 36px 0;
    max-width:520px;
    font-size:16px; /* requested */
    line-height:1.75;
    color:rgba(255,255,255,0.85);
  }

  .kx-tm__points{
    display:grid;
    gap:14px;
  }

  .kx-tm__point{
    display:flex;
    align-items:flex-start;
    gap:12px;
    font-size:14px;
    line-height:1.6;
    color:rgba(255,255,255,0.9);
  }

  .kx-tm__dot{
    width:8px;
    height:8px;
    margin-top:7px;
    border-radius:50%;
    background: #fff;
    box-shadow:0 0 0 4px rgba(255,255,255,0.25);
    flex-shrink:0;
  }

  /* right visual */
  .kx-tm__visual{
    display:flex;
    justify-content:center;
    align-items:center;
  }

  .kx-tm__imageWrap{
    width:100%;
    max-width:420px;
    aspect-ratio: 4 / 3;
    border-radius:22px;
    display:flex;
    align-items:center;
    justify-content:center;
    overflow:hidden;
  }

  .kx-tm__imageWrap img{
    width:100%;
    height:100%;
    object-fit:cover;
    display:block;
  }

  /* reveal */
  .kx-tm__reveal{
    opacity:0;
    transform:translateY(16px);
    transition:opacity 520ms ease, transform 520ms ease;
  }

  .kx-tm.is-inview .kx-tm__reveal{
    opacity:1;
    transform:translateY(0);
  }

  @media (max-width:980px){
    .kx-tm__card{
      grid-template-columns:1fr;
      padding:52px 40px;
    }
    .kx-tm__visual{
      order:-1;
    }
    .kx-tm__imageWrap{
      max-width:520px;
    }
  }

  @media (prefers-reduced-motion: reduce){
    .kx-tm__reveal{
      opacity:1 !important;
      transform:none !important;
      transition:none;
    }
  }
</style>

<script is:inline>
  (function(){
    var el = document.getElementById('kxTM');
    if(!el) return;

    // ensure main color fallback
    try{
      var mc = getComputedStyle(document.documentElement).getPropertyValue('--mainColor');
      if(!mc || !String(mc).trim()){
        document.documentElement.style.setProperty('--mainColor', '#01DCDC');
      }
    }catch(e){}

    if('IntersectionObserver' in window){
      var io = new IntersectionObserver(function(entries){
        if(entries[0].isIntersecting){
          el.classList.add('is-inview');
          io.disconnect();
        }
      },{threshold:0.25});
      io.observe(el);
    }else{
      el.classList.add('is-inview');
    }
  })();
</script>
