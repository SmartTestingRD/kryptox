---
/**
 * KYC.astro
 * ---------
 * 1:1 migration of part/sub/security/kyc.php. HTML, CSS and inline script
 * ported verbatim. `$raiz` resolves to `/`.
 */
---

<section class="kx-kyc" id="kxKyc">
  <div class="kx-kyc__inner">

    <div class="kx-kyc__gridlines" aria-hidden="true"></div>

    <div class="kx-kyc__top kx-kyc__reveal">
      <div class="kx-kyc__kicker">KYC / KYB</div>
      <h2 class="kx-kyc__title">KYC / KYB Integration</h2>
      <p class="kx-kyc__desc">
        Institutional onboarding built for regulated operations—validate entities, confirm beneficial ownership,
        and collect audit-ready evidence throughout the process.
      </p>
    </div>

    <div class="kx-kyc__items kx-kyc__reveal">
      <div class="kx-kyc__item">
        <div class="kx-kyc__icon" aria-hidden="true">
          <!-- Building / entity validation -->
          <img src="/media/office.svg" alt="">
        </div>
        <h3 class="kx-kyc__itemTitle">Entity Validation</h3>
        <p class="kx-kyc__itemDesc">
          Verify corporate identity, registration details, directors, and beneficial ownership—built for institutional KYB.
        </p>
      </div>

      <div class="kx-kyc__item">
        <div class="kx-kyc__icon" aria-hidden="true">
          <!-- Document / evidence -->
          <img src="/media/regulatory.svg" alt="">
        </div>
        <h3 class="kx-kyc__itemTitle">Regulatory Evidence</h3>
        <p class="kx-kyc__itemDesc">
          Capture documents, attestations, and supporting proof—organized and retained for compliance reviews and audits.
        </p>
      </div>

      <div class="kx-kyc__item">
        <div class="kx-kyc__icon" aria-hidden="true">
          <!-- Workflow / onboarding -->
          <img src="/media/checkpoint.svg" alt="">
        </div>
        <h3 class="kx-kyc__itemTitle">Institutional Onboarding</h3>
        <p class="kx-kyc__itemDesc">
          A structured onboarding flow with checkpoints, approvals, and status visibility—ready to plug into your operations.
        </p>
      </div>
    </div>

  </div>
</section>

<style>
  /* ===== Security & Compliance — KYC / KYB Integration ===== */

  .kx-kyc{
    background:#ffffff;
    padding:40px 28px 120px;
    position:relative;
    overflow:hidden;
  }

  .kx-kyc__inner{
    max-width: var(--innerWidth);
    margin:0 auto;
    position:relative;
  }

  /* subtle vertical grid lines like the reference */
  .kx-kyc__gridlines{
    position:absolute;
    inset:-120px -80px -120px -80px;
    pointer-events:none;
    opacity:0.22;
    background:
      linear-gradient(to right,
        rgba(0,0,0,0.08) 0px,
        rgba(0,0,0,0.08) 1px,
        transparent 1px,
        transparent 25%
      );
    background-size: 25% 100%;
  }

  .kx-kyc__top{
    text-align:center;
    max-width: 920px;
    margin: 0 auto 56px;
    position:relative;
    z-index:1;
  }

  .kx-kyc__kicker{
    margin:0 0 14px 0;
    font-size:12px;
    letter-spacing:0.18em;
    text-transform:uppercase;
    font-weight:800;
    color: color-mix(in srgb, var(--mainColor) 85%, #000);
  }

  .kx-kyc__title{
    margin:0 0 18px 0;
    font-size: clamp(34px, 4.6vw, 56px);
    line-height: 1.07;
    letter-spacing: -0.02em;
    font-weight: 200;
    color:#0a0f12;
  }

  .kx-kyc__desc{
    margin:0 auto;
    max-width: 760px;
    font-size: 16px;
    line-height: 1.75;
    color: rgba(10,15,18,0.62);
  }

  .kx-kyc__items{
    display:grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 38px;
    position:relative;
    z-index:1;
  }

  .kx-kyc__item{
    text-align:center;
    padding: 10px 14px;
  }

  .kx-kyc__icon{
    width: 46px;
    height: 46px;
    margin: 0 auto 14px;
    display:grid;
    place-items:center;
  }

  .kx-kyc__icon svg{
    width: 40px;
    height: 40px;
    stroke: currentColor;
    fill: none;
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  /* color accents like the reference (left purple, mid yellow, right orange)
     but still aligned with the project palette */
  .kx-kyc__item:nth-child(1) .kx-kyc__icon{ color: #2E44F0; }   /* cobalt/purple */
  .kx-kyc__item:nth-child(2) .kx-kyc__icon{ color: #D46A18; }   /* orange from palette */
  .kx-kyc__item:nth-child(3) .kx-kyc__icon{ color: var(--mainColor); } /* main */

  .kx-kyc__itemTitle{
    margin: 0 0 10px;
    font-size: 18px;
    font-weight: 500;
    color:#0a0f12;
  }

  .kx-kyc__itemDesc{
    margin:0 auto;
    max-width: 320px;
    font-size: 14px;
    line-height: 1.7;
    color: rgba(10,15,18,0.60);
  }

  /* reveal */
  .kx-kyc__reveal{
    opacity:0;
    transform: translateY(14px);
    transition: opacity 520ms ease, transform 520ms ease;
  }
  .kx-kyc.is-inview .kx-kyc__reveal{
    opacity:1;
    transform: translateY(0);
  }

  @media (max-width: 980px){
    .kx-kyc__items{
      grid-template-columns: 1fr;
      gap: 26px;
    }
    .kx-kyc__gridlines{
      opacity:0.16;
      background-size: 33.33% 100%;
    }
  }

  @media (prefers-reduced-motion: reduce){
    .kx-kyc__reveal{
      opacity:1 !important;
      transform:none !important;
      transition:none !important;
    }
  }
</style>

<script is:inline>
  (function(){
    var el = document.getElementById('kxKyc');
    if(!el) return;

    // main color fallback
    try{
      var mc = getComputedStyle(document.documentElement).getPropertyValue('--mainColor');
      if(!mc || !String(mc).trim()){
        document.documentElement.style.setProperty('--mainColor', '#01DCDC');
      }
    }catch(e){}

    if('IntersectionObserver' in window){
      var io = new IntersectionObserver(function(entries){
        if(entries[0].isIntersecting){
          el.classList.add('is-inview');
          io.disconnect();
        }
      },{threshold:0.22});
      io.observe(el);
    }else{
      el.classList.add('is-inview');
    }
  })();
</script>
