---
/**
 * Access.astro
 * ------------
 * 1:1 migration of part/sub/security/access.php. HTML, CSS and inline
 * script ported verbatim.
 */
---

<section class="kx-iag" id="kxIAG">
  <div class="kx-iag__inner">
    <div class="kx-iag__card kx-iag__reveal">

      <div class="kx-iag__badge">
        Identity &amp; Governance
      </div>

      <h2 class="kx-iag__title">
        Identity, Access &amp; Governance by Design
      </h2>

      <p class="kx-iag__desc">
        KryptoX enforces strong identity controls, role-based access, and approval hierarchies
        to guarantee a clear separation of responsibilities across every operational workflow.
        Every action is intentional, permissioned, and fully auditable.
      </p>

      <div class="kx-iag__features">
        <div class="kx-iag__feature">
          <h4>Role-Based Access Control</h4>
          <p>
            Define granular permissions for operators, reviewers, and administrators—ensuring
            access is always aligned with responsibility.
          </p>
        </div>

        <div class="kx-iag__feature">
          <h4>Approval Hierarchies</h4>
          <p>
            Configure multi-level approval flows with thresholds, quorum rules, and escalation
            paths for high-risk operations.
          </p>
        </div>

        <div class="kx-iag__feature">
          <h4>Governance &amp; Auditability</h4>
          <p>
            Every identity action and approval decision is logged, traceable, and ready for
            internal reviews or regulatory audits.
          </p>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  /* ===== Security & Compliance — Identity, Access & Governance ===== */

  .kx-iag{
    background:#ffffff;
    padding:40px 28px 170px;
    display:flex;
    justify-content:center;
  }

  .kx-iag__inner{
    max-width: var(--innerWidth);
    width:100%;
    display:flex;
    justify-content:center;
  }

  .kx-iag__card{
    position:relative;
    width:100%;
    max-width:980px;
    border-radius:26px;
    padding:56px 60px 60px;
    color:#ffffff;
    background: #525252;  /* fallback for old browsers */
background: -webkit-linear-gradient(to right, #4190A1, #525252);  /* Chrome 10-25, Safari 5.1-6 */
background: linear-gradient(to right, #4190A1, #525252); /* W3C, IE 10+/ Edge, Firefox 16+, Chrome 26+, Opera 12+, Safari 7+ */
    box-shadow:
      0 40px 120px rgba(0,0,0,0.45),
      inset 0 0 0 1px rgba(255,255,255,0.08);
    overflow:hidden;
  }

  /* subtle brand accent */
  /*.kx-iag__card::after{
    content:"";
    position:absolute;
    top:-120px;
    right:-120px;
    width:320px;
    height:320px;
    background: radial-gradient(circle, color-mix(in srgb, var(--mainColor) 35%, transparent) 0%, transparent 70%);
    opacity:0.8;
    pointer-events:none;
  }*/

  .kx-iag__badge{
    display:inline-flex;
    align-items:center;
    gap:10px;
    padding:8px 16px;
    border-radius:999px;
    background:rgba(255,255,255,0.12);
    font-size:12px;
    font-weight:600;
    letter-spacing:0.04em;
    text-transform:uppercase;
    color:#ffffff;
    margin-bottom:28px;
  }

  .kx-iag__badge::before{
    content:"";
    width:8px;
    height:8px;
    border-radius:50%;
    background: var(--mainColor);
    box-shadow:0 0 0 4px color-mix(in srgb, var(--mainColor) 25%, transparent);
  }

  .kx-iag__title{
    margin:0 0 20px;
    font-size:clamp(34px, 4.5vw, 56px);
    line-height:1.08;
    font-weight:400;
    letter-spacing:-0.02em;
    color:#ffffff;
    max-width:760px;
  }

  .kx-iag__desc{
    margin:0 0 40px;
    max-width:760px;
    font-size:15px;
    line-height:1.7;
    color:rgba(255,255,255,0.75);
  }

  .kx-iag__features{
    display:grid;
    grid-template-columns:repeat(3,1fr);
    gap:26px;
  }

  .kx-iag__feature{
    background:rgba(255,255,255,0.06);
    border-radius:16px;
    padding:22px 22px 24px;
    box-shadow:inset 0 0 0 1px rgba(255,255,255,0.08);
  }

  .kx-iag__feature h4{
    margin:0 0 10px;
    font-size:15px;
    font-weight:700;
    color:#ffffff;
  }

  .kx-iag__feature p{
    margin:0;
    font-size:13px;
    line-height:1.6;
    color:rgba(255,255,255,0.7);
  }

  /* reveal animation */
  .kx-iag__reveal{
    opacity:0;
    transform:translateY(14px);
    transition:opacity 520ms ease, transform 520ms ease;
  }

  .kx-iag.is-inview .kx-iag__reveal{
    opacity:1;
    transform:translateY(0);
  }

  @media (max-width:900px){
    .kx-iag__card{
      padding:44px 36px 46px;
    }
    .kx-iag__features{
      grid-template-columns:1fr;
    }
  }

  @media (prefers-reduced-motion: reduce){
    .kx-iag__reveal{
      opacity:1 !important;
      transform:none !important;
      transition:none;
    }
  }
</style>

<script is:inline>
  (function(){
    var el = document.getElementById('kxIAG');
    if(!el) return;

    // main color fallback
    try{
      var mc = getComputedStyle(document.documentElement).getPropertyValue('--mainColor');
      if(!mc || !String(mc).trim()){
        document.documentElement.style.setProperty('--mainColor', '#01DCDC');
      }
    }catch(e){}

    if('IntersectionObserver' in window){
      var io = new IntersectionObserver(function(entries){
        if(entries[0].isIntersecting){
          el.classList.add('is-inview');
          io.disconnect();
        }
      },{threshold:0.25});
      io.observe(el);
    }else{
      el.classList.add('is-inview');
    }
  })();
</script>
