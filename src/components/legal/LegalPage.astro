---
/**
 * LegalPage.astro
 * ---------------
 * 1:1 migration of part/page/base.legal.php — the shared legal-page
 * template used by privacy / terms / cookies / risk-disclosure.
 *
 * PHP `$title` / `$date` become props; PHP `<?php echo $body ?>` becomes a
 * <slot/> so each page supplies its body HTML verbatim.
 *
 * The <style> is global: the slotted body markup is authored in the page
 * component (a different Astro scope), so scoped selectors would not reach
 * it. All `.legal_template__*` class names are uniquely prefixed.
 */
interface Props {
  title: string;
  date: string;
}

const { title, date } = Astro.props;
---

<section class="legal_template">
  <div class="legal_template__topbar"></div>

  <div class="legal_template__wrap">
    <div class="legal_template__card">
      <div class="legal_template__content">
        <h1 class="legal_template__title">{title}</h1>
        <p class="legal_template__effective">Effective as from {date}</p>

        <div class="legal_template__body">
          <slot />
        </div>
      </div>
    </div>
  </div>
</section>

<style is:global>
.legal_template{
  position:relative;
  background:#f3f3f3;
  min-height:100vh;
  overflow:hidden;
}

.legal_template__topbar{
  height:340px;
  background:#000;
}

.legal_template__wrap{
  position:relative;
  width:min(1140px, calc(100% - 48px));
  margin:-270px auto 0;
  padding:0 0 80px;
}

.legal_template__card{
  position:relative;
  background:#fff;
  border-radius:25px;
  min-height:620px;
  box-shadow:0 34px 70px rgba(0,0,0,.14);
  overflow:visible;
  margin-top: 40px;
}

.legal_template__card::after{
  content:"";
  position:absolute;
  left:32px;
  right:32px;
  bottom:-18px;
  height:56px;
  border-radius:0 0 28px 28px;
  background:rgba(0,0,0,.08);
  filter:blur(24px);
  z-index:-1;
  pointer-events:none;
}

.legal_template__content{
  position:relative;
  z-index:2;
  padding:62px 72px 84px;
  /*max-width:1040px;*/
}

.legal_template__title{
  margin:0;
  font-size:38px;
  line-height:1.02;
  font-weight:600;
  letter-spacing:-0.04em;
  color:#050505;
}

.legal_template__effective{
  margin:22px 0 0;
  font-size:16px;
  line-height:1.45;
  color:#555;
}

.legal_template__body{
  margin-top:74px;
}

.legal_template__body p{
  margin:0 0 26px;
  font-size: 16px;
  line-height:1.72;
  color:#1a1a1a;
}

.legal_template__body h2{
  margin:54px 0 18px;
  font-size:22px;
  line-height:1.15;
  font-weight:600;
  letter-spacing:-0.03em;
  color:#0b0b0b;
}

.legal_template__body ul{
  margin:0 0 30px;
  padding:0 0 0 24px;
}

.legal_template__body li{
  margin:0 0 14px;
  font-size:21px;
  line-height:1.68;
  color:#1a1a1a;
}

.legal_template__body strong{
  font-weight:600;
  color:#000;
}

.legal_template__body a{
  color:#5f48ff;
  text-decoration:none;
}

.legal_template__body a:hover{
  text-decoration:underline;
}

.legal_template__divider{
  width:100%;
  height:1px;
  margin:42px 0;
  background:rgba(0,0,0,.08);
}

@media (max-width: 1200px){
  .legal_template__topbar{
    height:300px;
  }

  .legal_template__wrap{
    margin-top:-236px;
  }

  .legal_template__content{
    padding:54px 48px 76px;
  }

  .legal_template__title{
    font-size:48px;
  }

  .legal_template__body p,
  .legal_template__body li{
    font-size:19px;
  }
}

@media (max-width: 820px){
  .legal_template__topbar{
    height:240px;
  }

  .legal_template__wrap{
    width:min(100% - 28px, 1280px);
    margin-top:-186px;
    padding-bottom:56px;
  }

  .legal_template__card{
    border-radius:26px;
    min-height:420px;
  }

  .legal_template__card::after{
    left:18px;
    right:18px;
    bottom:-12px;
    height:44px;
    filter:blur(18px);
  }

  .legal_template__content{
    padding:36px 24px 56px;
  }

  .legal_template__title{
    font-size:38px;
  }

  .legal_template__effective{
    margin-top:16px;
    font-size:17px;
  }

  .legal_template__body{
    margin-top:46px;
  }

  .legal_template__body h2{
    font-size:25px;
    margin-top:38px;
  }

  .legal_template__body p,
  .legal_template__body li{
    font-size:17px;
    line-height:1.66;
    margin-bottom:20px;
  }
}
</style>

<script is:inline>
(function(){
  var legalTemplate = document.querySelector('.legal_template');
  if(!legalTemplate) return;

  function syncLegalMinHeight(){
    var card = legalTemplate.querySelector('.legal_template__card');
    var content = legalTemplate.querySelector('.legal_template__content');
    if(!card || !content) return;

    if(window.innerWidth <= 820){
      card.style.minHeight = Math.max(420, Math.round(window.innerHeight * 0.42)) + 'px';
    }else{
      card.style.minHeight = '620px';
    }
  }

  syncLegalMinHeight();
  window.addEventListener('resize', syncLegalMinHeight);
})();
</script>
